[global]
    # Which monitor should the notifications be displayed on.
    monitor = 0
    follow = none

    # Show how many messages are currently hidden
    indicate_hidden = yes

		# Appearance
		geometry = "0x0-30+20"
    transparency = 0
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    corner_radius = 5
    frame_width = 3
    frame_color = "#aaaaaa"
    separator_color = auto
    font = JetBrains Mono Medium 10
    markup = full
    alignment = center
    format = "<b>%s</b>\n%b"
    ellipsize = middle
    line_height = 0
    icon_position = left
    min_icon_size = 32
		show_indicators = yes
    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/
    stack_duplicates = true
    ignore_newline = no

    # Sort messages by urgency.
    sort = yes

    ### Text ###
    show_age_threshold = 60

    # Hide the count of stacked notifications with the same content
    hide_duplicate_count = false

    ### History ###

    # Should a notification popped up from history be sticky or timeout
    # as if it would normally do.
    sticky_history = yes

    # Maximum amount of notifications kept in history
    history_length = 20

    ### Misc/Advanced ###

    # Define the title & class of the windows spawned by dunst
    title = Dunst
    class = Dunst

    ### mouse
    mouse_left_click = close_current

[urgency_low]
    background = "#2b2b2b"
    foreground = "#ffffff"
    timeout = 5
    default_icon = /home/ben/.config/dunst/normal.png

[urgency_normal]
    background = "#2b2b2b"
    foreground = "#ffffff"
    timeout = 5
    default_icon = /home/ben/.config/dunst/normal.png

[urgency_critical]
    background = "#900000"
    foreground = "#ffffff"
    frame_color = "#ff0000"
    timeout = 5
    default_icon = /home/ben/.config/dunst/critical.png
